# ============================================================
# HeartLink Arena - Frontend Environment Variables (Vite)
# ============================================================
# Copy this file to .env and fill in your values.
# All variables MUST be prefixed with VITE_ to be exposed
# to the browser bundle by Vite.
# Reference in code: import.meta.env.VITE_VARIABLE_NAME
# ============================================================

# --- Backend API ---
# Base URL for the Spring Boot backend API.
# In development, Vite proxies /api → http://localhost:8080,
# so this is only needed when not using the dev proxy (e.g. production build).
VITE_API_BASE_URL=http://localhost:8080

# --- External Heart Game API ---
# Direct URL to the Heart card game API (used for image assets / direct calls).
VITE_HEART_API_URL=https://marcconrad.com/uob/heart/api.php

# --- App Environment ---
# Options: development | production
VITE_APP_ENV=development
