# ============================================================
# HeartLink Arena - Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Spring Boot reads these as environment variables using the
# relaxed binding convention (dots replaced with underscores,
# all uppercase). Alternatively, copy application.yml.example
# to application.yml and fill in values there.
# ============================================================

# --- Server ---
SERVER_PORT=8080

# --- PostgreSQL / Supabase Database ---
# Format: jdbc:postgresql://<host>:<port>/<database>?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_SUPABASE_HOST:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=YOUR_PASSWORD_HERE
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# --- HikariCP Connection Pool ---
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=5

# --- JPA / Hibernate ---
# Options: validate | update | create | create-drop
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# --- External Heart Game API ---
# Base URL for the Heart card game API
HEART_API_BASE_URL=https://marconrad.com/uob/heart

# --- App Feature Flags ---
# Set to false to use the live external API instead of mock data
APP_USE_MOCK_API=true

# --- CORS ---
# Comma-separated list of allowed frontend origins
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- OpenWeatherMap API ---
# Get your key at: https://openweathermap.org/api
# If left as the placeholder or if APP_USE_MOCK_API=true, mock weather data is returned.
# NOTE: The base URL (https://api.openweathermap.org/data/2.5) is hardcoded in
#       WebClientConfig.java and is NOT configurable via an environment variable.
WEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY_HERE

# --- GitHub Actions / Docker Hub (CI/CD only, set in GitHub Secrets) ---
# DOCKERHUB_USERNAME=your_dockerhub_username
# DOCKERHUB_TOKEN=your_dockerhub_access_token
